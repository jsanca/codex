+                .status(ContentItemStatus.PUBLISHED)
+                .currentPublishedRevisionId(published.id())
+                .currentWorkingRevisionId(published.id())
+                .updatedBy(actor.id())
+                .updatedAt(clock.instant())
+                .build();
+        final ContentItem saved = repository.save(updated);
