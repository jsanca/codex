+                .orElseThrow(() -> new NotFoundException("ContentRevision not found: "
+                        + item.currentWorkingRevisionId().value()));
+
+        if (working.status() == ContentRevisionStatus.ARCHIVED) {
+            throw new InvalidContentItemPublishException(item.key(),
